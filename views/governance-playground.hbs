            <h3>📍 JSON Path Matches</h3>
            <span class="toggle-icon">▼</span>
          </div>
          <div class="results-content" id="jsonPathResultsContent">
            <table class="resultTable" id="jsonPathResultTable">
              <thead>
                <tr>
                  <th style="width: 35%;">JSONPath Expression</th>
                  <th>Matched Values</th>
                </tr>
              </thead>
              <tbody id="jsonPathTableResultsBody">
